# ── Telegram ───────────────────────────────────────────────
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Твой личный Telegram user id (числом). Только с него принимаются ответы.
# Если не знаешь — оставь пустым, запусти мост, напиши боту /id, он подскажет.
TELEGRAM_OWNER_ID=

# ── MAX ────────────────────────────────────────────────────
# Номер телефона аккаунта MAX в международном формате
MAX_PHONE=+79990000000

# ── Прочее ─────────────────────────────────────────────────
# Папка для файла сессии MAX и служебного кэша
WORK_DIR=./data
# Имя файла SQLite-сессии MAX внутри WORK_DIR
MAX_SESSION=max_session.db
# Файл SQLite для маршрутизации ответов TG -> MAX
MAPPING_DB=./data/mapping.db

# Пересылать сообщения из групп/каналов MAX (true), или только личные диалоги (false)
FORWARD_GROUPS=false
