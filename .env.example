# ── Telegram ───────────────────────────────────────────────
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Твой личный Telegram user id (числом). Только с него принимаются ответы.
# Если не знаешь — оставь пустым, запусти мост, напиши боту /id, он подскажет.
TELEGRAM_OWNER_ID=

# Режим тем (опционально). Если задать id группы-форума, каждый чат MAX
# попадёт в отдельную тему этой группы (как «подчаты»). Пусто — всё приходит
# в личку с ботом, как обычно.
# Группа должна быть с включёнными «Темами», а бот — её админом с правом
# «Управление темами». Узнать id: добавь бота в группу и напиши там /id.
TELEGRAM_GROUP_ID=

# ── MAX ────────────────────────────────────────────────────
# Номер телефона аккаунта MAX в международном формате
MAX_PHONE=+79990000000

# ── Прочее ─────────────────────────────────────────────────
# Папка для файла сессии MAX и служебного кэша
WORK_DIR=./data
# Имя файла SQLite-сессии MAX внутри WORK_DIR
MAX_SESSION=max_session.db
# Файл SQLite для маршрутизации ответов TG -> MAX
MAPPING_DB=./data/mapping.db

# Пересылать сообщения из групп/каналов MAX (true), или только личные диалоги (false)
FORWARD_GROUPS=false

# Отмечать сообщение в MAX прочитанным, когда ты на него отвечаешь (true/false)
MARK_READ=true

# Прокси для подключения к MAX. Нужен, если сервер НЕ в стране твоего телефона
# (иначе MAX блокирует вход как подозрительный). Рекомендуется HTTP(S)-прокси
# с IP в твоём регионе — он работает и для входа, и для выгрузки вложений.
# Примеры:
#   MAX_PROXY=http://user:pass@1.2.3.4:8080
#   MAX_PROXY=http://1.2.3.4:8080
#   MAX_PROXY=socks5://user:pass@1.2.3.4:1080   (переписка ок, выгрузка файлов может не работать)
# Пусто — без прокси.
MAX_PROXY=
