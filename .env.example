# ── Telegram ───────────────────────────────────────────────
# Токен бота от @BotFather. Один бот обслуживает всех пользователей —
# каждый добавляет свои MAX-аккаунты сам, командой /add в личке с ботом.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# ── Прочее ─────────────────────────────────────────────────
# Папка для сессий MAX, баз и логов.
WORK_DIR=./data

# Реестр аккаунтов (кто какой MAX добавил). По умолчанию <WORK_DIR>/registry.db
# REGISTRY_DB=

# Уровень логов: INFO (по умолчанию), WARNING (тише), DEBUG (всё подробно).
LOG_LEVEL=INFO

# Автоочистка логов (ротация файла). Потолок = LOG_MAX_MB * (LOG_BACKUPS + 1).
# LOG_FILE: путь (по умолчанию <WORK_DIR>/bridge.log; off — выключить).
LOG_FILE=
LOG_MAX_MB=5
LOG_BACKUPS=3

# ── Миграция со старой single-версии (необязательно) ───────
# Если раньше был один аккаунт из .env — заполни эти поля, и при первом
# запуске он автоматически перенесётся в реестр (без повторного входа).
# Нужны только один раз; после миграции можно удалить.
TELEGRAM_OWNER_ID=
MAX_PHONE=
TELEGRAM_GROUP_ID=
MAX_SESSION=max_session.db
MAPPING_DB=
MAX_PROXY=
